# Server port (default: 4001)
PORT=4001

# SMTP configuration for sending emails (clarifications, feedback notifications)
# Required for email to students. If not set, notes are saved in-app but no email is sent.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Gmail: Use an App Password, not your regular password.
# Go to Google Account → Security → 2-Step Verification → App passwords.
# Create one for "Mail" and paste it as SMTP_PASS.

# Other providers:
# Outlook: SMTP_HOST=smtp.office365.com, SMTP_PORT=587
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASS=your-api-key
